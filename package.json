{
  "name": "@clint419/websearch-mcp-server",
  "version": "1.0.1",
  "description": "Standalone MCP server for Exa/Parallel free web search",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "websearch-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "websearch",
    "exa",
    "parallel",
    "ai",
    "search"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "htmlparser2": "^12.0.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
